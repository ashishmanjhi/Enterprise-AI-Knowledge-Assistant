# Application Configuration
APP_NAME=Enterprise Agentic RAG Platform
APP_VERSION=10.0.0
ENVIRONMENT=development
DEBUG=true

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_platform
DB_USER=rag_user
DB_PASSWORD=changeme

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_CTX=4096

# Hugging Face Configuration
HF_HOME=./models
HF_DEFAULT_MODEL=Qwen/Qwen2.5-3B-Instruct
HF_CACHE_DIR=

# LLM Provider Configuration
DEFAULT_PROVIDER=ollama
FALLBACK_PROVIDER=huggingface

# Generation Defaults
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=512

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# CORS Configuration
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true

# Evaluation (Phase 5)
# EVAL_JUDGE_MODEL=
# EVAL_JUDGE_PROVIDER=
EVAL_MAX_SAMPLES=50

# Conversational Memory (Phase 6)
MEMORY_SESSION_TTL=86400
MEMORY_MAX_HISTORY_MESSAGES=20
MEMORY_ENABLE_SUMMARISATION=true
MEMORY_SUMMARY_THRESHOLD=10

# Safety & Governance — Guardrails (Phase 7)
GUARDRAILS_ENABLE_INJECTION=true
GUARDRAILS_ENABLE_TOXICITY=true
GUARDRAILS_ENABLE_PII=true
GUARDRAILS_ENABLE_HALLUCINATION=true
GUARDRAILS_BLOCK_ON_INJECTION=true
GUARDRAILS_BLOCK_ON_TOXICITY=true
GUARDRAILS_BLOCK_ON_PII_INPUT=false
GUARDRAILS_BLOCK_ON_HALLUCINATION=false

# Agentic RAG (Phase 9)
AGENT_ENABLE_DOCUMENT_GRADING=true
AGENT_ENABLE_GROUNDING_CHECK=true
AGENT_MAX_REWRITES=2

# Production Auth (Phase 10)
# Set AUTH_ENABLED=true to require JWT on all API routes.
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production-use-a-32-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Cloud LLM Providers (Phase 10) — uncomment and fill in to activate
# OPENAI_API_KEY=sk-...
# DEFAULT_PROVIDER=openai

# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_PROVIDER=anthropic

# GOOGLE_API_KEY=...
# DEFAULT_PROVIDER=gemini

# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01
# DEFAULT_PROVIDER=azure

# LangSmith Tracing (Phase 10) — set LANGSMITH_ENABLED=true to activate
LANGSMITH_ENABLED=false
# LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=enterprise-rag-platform

# OpenTelemetry (Phase 10) — set OTEL_ENABLED=true to send spans to a collector
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-rag-platform

# Feedback (Phase 10)
FEEDBACK_STORE_PATH=data/feedback.jsonl
