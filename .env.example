# =============================================================================
# Enterprise Agentic RAG Platform — Environment Configuration
# Version: 14.0.0  |  Copy this file to .env and fill in your values
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=Enterprise Agentic RAG Platform
APP_VERSION=14.0.0
ENVIRONMENT=development
DEBUG=true

# ---------------------------------------------------------------------------
# API
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=rag_platform
DB_USER=rag_user
DB_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Redis (Conversational Memory — Phase 6)
# ---------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ---------------------------------------------------------------------------
# Ollama (Local LLM — all phases)
# ---------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:4b
OLLAMA_TIMEOUT=300
OLLAMA_NUM_CTX=4096

# ---------------------------------------------------------------------------
# Hugging Face
# ---------------------------------------------------------------------------
HF_HOME=./models
HF_DEFAULT_MODEL=Qwen/Qwen2.5-3B-Instruct
HF_CACHE_DIR=

# ---------------------------------------------------------------------------
# LLM Provider
# ---------------------------------------------------------------------------
DEFAULT_PROVIDER=ollama
FALLBACK_PROVIDER=huggingface

# ---------------------------------------------------------------------------
# Generation Defaults
# ---------------------------------------------------------------------------
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=512

# ---------------------------------------------------------------------------
# RAG Configuration (Phase 1)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSION=384
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5

# ---------------------------------------------------------------------------
# Document Storage (Phase 1)
# ---------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_DIR=data/raw
PROCESSED_DIR=data/processed
VECTORSTORE_DIR=data/vectorstore
FAISS_INDEX_PATH=data/vectorstore/faiss_index.bin
METADATA_PATH=data/vectorstore/metadata.json

# ---------------------------------------------------------------------------
# BM25 & Hybrid Retrieval (Phase 2)
# ---------------------------------------------------------------------------
BM25_INDEX_PATH=data/vectorstore/bm25_index.pkl
BM25_K1=1.5
BM25_B=0.75
DEFAULT_RETRIEVAL_METHOD=hybrid
FAISS_WEIGHT=0.5
BM25_WEIGHT=0.5
RRF_K=60

# ---------------------------------------------------------------------------
# Query Understanding (Phase 3)
# ---------------------------------------------------------------------------
ENABLE_QUERY_REFORMULATION=true
ENABLE_QUERY_EXPANSION=true
ENABLE_HYDE=true
NUM_QUERY_EXPANSIONS=3

# ---------------------------------------------------------------------------
# Reranking (Phase 4)
# ---------------------------------------------------------------------------
ENABLE_RERANKING=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N=3

# ---------------------------------------------------------------------------
# Evaluation / RAGAS (Phase 5)
# ---------------------------------------------------------------------------
# EVAL_JUDGE_MODEL=
# EVAL_JUDGE_PROVIDER=
EVAL_MAX_SAMPLES=50

# ---------------------------------------------------------------------------
# Conversational Memory (Phase 6)
# ---------------------------------------------------------------------------
MEMORY_SESSION_TTL=86400
MEMORY_MAX_HISTORY_MESSAGES=20
MEMORY_ENABLE_SUMMARISATION=true
MEMORY_SUMMARY_THRESHOLD=10

# ---------------------------------------------------------------------------
# Safety & Governance — Guardrails (Phase 7)
# ---------------------------------------------------------------------------
GUARDRAILS_ENABLE_INJECTION=true
GUARDRAILS_ENABLE_TOXICITY=true
GUARDRAILS_ENABLE_PII=true
GUARDRAILS_ENABLE_HALLUCINATION=true
GUARDRAILS_BLOCK_ON_INJECTION=true
GUARDRAILS_BLOCK_ON_TOXICITY=true
GUARDRAILS_BLOCK_ON_PII_INPUT=false
GUARDRAILS_BLOCK_ON_HALLUCINATION=false

# ---------------------------------------------------------------------------
# Agentic RAG (Phase 9)
# ---------------------------------------------------------------------------
AGENT_ENABLE_DOCUMENT_GRADING=true
AGENT_ENABLE_GROUNDING_CHECK=true
AGENT_MAX_REWRITES=2

# ---------------------------------------------------------------------------
# Production Auth (Phase 10)
# Set AUTH_ENABLED=true to require JWT on all API routes
# ---------------------------------------------------------------------------
AUTH_ENABLED=false
JWT_SECRET_KEY=change-me-in-production-use-a-32-char-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
# Demo credentials — CHANGE THESE before any non-local deployment (F-02)
AUTH_ADMIN_PASSWORD=changeme
AUTH_USER_PASSWORD=changeme

# ---------------------------------------------------------------------------
# Cloud LLM Providers (Phase 10) — uncomment and fill in to activate
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...
# DEFAULT_PROVIDER=openai

# ANTHROPIC_API_KEY=sk-ant-...
# DEFAULT_PROVIDER=anthropic

# GOOGLE_API_KEY=...
# DEFAULT_PROVIDER=gemini

# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-02-01
# DEFAULT_PROVIDER=azure

# ---------------------------------------------------------------------------
# LangSmith Tracing (Phase 10)
# ---------------------------------------------------------------------------
LANGSMITH_ENABLED=false
# LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=enterprise-rag-platform

# ---------------------------------------------------------------------------
# OpenTelemetry (Phase 10)
# ---------------------------------------------------------------------------
OTEL_ENABLED=false
OTEL_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=enterprise-rag-platform

# ---------------------------------------------------------------------------
# Feedback (Phase 10)
# ---------------------------------------------------------------------------
FEEDBACK_STORE_PATH=data/feedback.jsonl

# ---------------------------------------------------------------------------
# Multi-Agent Ecosystem (Phase 11)
# ---------------------------------------------------------------------------
RESEARCH_AGENT_MAX_SUB_QUESTIONS=4
RETRIEVAL_AGENT_EXPANSIONS=3
EVAL_AGENT_PASS_THRESHOLD=0.4
EVAL_AGENT_USE_RAGAS=false
KNOWLEDGE_AGENT_MAX_ENTITIES=5

# ---------------------------------------------------------------------------
# Knowledge Graph Enhancement (Phase 12)
# ---------------------------------------------------------------------------
KG_PERSIST_PATH=data/knowledge_graph.json
KG_MAX_ENTITIES_PER_DOC=50
KG_MAX_RELATIONS_PER_DOC=30
KG_NEIGHBOUR_HOPS=2
KG_MAX_SUBGRAPH_NODES=50
KG_HYBRID_VECTOR_WEIGHT=0.6
KG_HYBRID_GRAPH_WEIGHT=0.4
KG_LLM_EXTRACTION_ENABLED=true
KG_EXTRACTION_MAX_TOKENS=300

# ---------------------------------------------------------------------------
# Enhanced PDF Ingestion (Phase 13)
# ---------------------------------------------------------------------------
PDF_USE_ENHANCED_LOADER=true
PDF_TABLE_FORMAT=markdown
PDF_OCR_FALLBACK=true
PDF_OCR_MIN_TEXT_LEN=20
PDF_TABLE_CHUNK_PREFIX=[TABLE]
PDF_MAX_TABLE_CHUNK_CHARS=2000

# ---------------------------------------------------------------------------
# Chart & Image Understanding (Phase 14 — requires llava:7b via Ollama)
# Set PDF_CHART_DESCRIPTION_ENABLED=false to skip llava calls during bulk ingestion
# ---------------------------------------------------------------------------
PDF_CHART_DESCRIPTION_ENABLED=true
PDF_CHART_MODEL=llava:7b
PDF_CHART_MIN_AREA_PTS=5000
PDF_CHART_RENDER_DPI=150
PDF_CHART_MAX_PER_PAGE=3
PDF_CHART_CHUNK_PREFIX=[CHART]

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=5

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
